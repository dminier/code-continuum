{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug: examples folder",
            "cargo": {
                "args": [
                    "build",
                    "--bin=code-continuum",
                    "--package=code-continuum"
                ],
                "filter": {
                    "name": "code-continuum",
                    "kind": "bin"
                }
            },
            "args": [
                "examples/"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "sourceLanguages": ["rust"],
            "stopOnEntry": false,
            "env": {
                "RUST_LOG": "info",
                "NEO4J_URI": "bolt://neo4j:7687",
                "NEO4J_USER": "neo4j",
                "NEO4J_PASSWORD": "password"
            }
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug: Analyser le projet demo",
            "cargo": {
                "args": [
                    "build",
                    "--bin=code-continuum",
                    "--package=code-continuum"
                ],
                "filter": {
                    "name": "code-continuum",
                    "kind": "bin"
                }
            },
            "args": [
                "/demo-portlets"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "sourceLanguages": ["rust"],
            "stopOnEntry": false,
            "env": {
                "RUST_LOG": "info",
                "NEO4J_URI": "bolt://neo4j:7687",
                "NEO4J_USER": "neo4j",
                "NEO4J_PASSWORD": "password",
                "INCLUDE_PACKAGES": "com.example.*,javax.portlet.*"
            }
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug: Custom path (prompt)",
            "cargo": {
                "args": [
                    "build",
                    "--bin=code-continuum",
                    "--package=code-continuum"
                ],
                "filter": {
                    "name": "code-continuum",
                    "kind": "bin"
                }
            },
            "args": [
                "${input:projectPath}"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "sourceLanguages": ["rust"],
            "stopOnEntry": false,
            "env": {
                "RUST_LOG": "info",
                "NEO4J_URI": "bolt://neo4j:7687",
                "NEO4J_USER": "neo4j",
                "NEO4J_PASSWORD": "password"
            }
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug: MCP Server",
            "cargo": {
                "args": [
                    "build",
                    "--bin=code-continuum",
                    "--package=code-continuum"
                ],
                "filter": {
                    "name": "code-continuum",
                    "kind": "bin"
                }
            },
            "args": [
                "--mcp"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "sourceLanguages": ["rust"],
            "stopOnEntry": false,
            "env": {
                "RUST_LOG": "warn",
                "NEO4J_URI": "bolt://neo4j:7687",
                "NEO4J_USER": "neo4j",
                "NEO4J_PASSWORD": "password"
            }
        }
    ],
    "inputs": [
        {
            "id": "projectPath",
            "type": "promptString",
            "description": "Path to project directory to analyze",
            "default": "examples/"
        }
    ]
}
