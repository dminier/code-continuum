# ============================================================
# Production Environment Configuration
# ============================================================
# Copy this file to .env and update values for production
# ============================================================

# Neo4j Database
NEO4J_PASSWORD=your_strong_production_password_here
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j

# Code Path to Analyze
CODE_PATH=./examples

# Logging Level
# Options: error, warn, info, debug, trace
RUST_LOG=info

# Backtrace (set to 1 for debugging)
RUST_BACKTRACE=0

# MCP Server (future)
# MCP_PORT=8000
# MCP_API_KEY=your_api_key_here
