{
	"name": "Rust - Code Graph RAG with Neo4j",
	"dockerComposeFile": "docker-compose.yml",
	"service": "app",
	"workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
	"remoteUser": "vscode",
	"customizations": {
		"vscode": {
			"extensions": [
				"rust-lang.rust-analyzer",
				"vadimcn.vscode-lldb",
				"serayuzgur.crates",
				"dustypomerleau.rust-syntax",
				"tamasfe.even-better-toml",
				"ms-vscode.makefile-tools",
				"anthropic.claude-code"
			],
			"settings": {
				"[rust]": {
					"editor.formatOnSave": true,
					"editor.defaultFormatter": "rust-lang.rust-analyzer"
				},
				"rust-analyzer.checkOnSave.command": "clippy",
				"rust-analyzer.inlayHints.enable": true,
				"rust-analyzer.diagnostics.experimental.enable": true,
				"editor.rulers": [80, 100, 120],
				"files.watcherExclude": {
					"**/target/**": true
				}
			}, 
			"mcp": {
				"servers": {
					"code-continuum": {
						"command": "bash",
						"args": ["-c", "cd /workspaces/code-continuum && ./target/debug/code-continuum --mcp"],
						"env": {
							"RUST_LOG": "info"
						}
					}
				}
			}
		}
	},
	
	// Forward ports for Neo4j
	"forwardPorts": [7474, 7687],
	"portsAttributes": {
		"7474": {
			"label": "Neo4j Browser",
			"onAutoForward": "notify"
		},
		"7687": {
			"label": "Neo4j Bolt",
			"onAutoForward": "silent"
		}
	},
	
	// Post-create command to install dependencies
	"postCreateCommand": "chmod 700 ~/.ssh && chmod 600 ~/.ssh/* 2>/dev/null || true && cargo check && cargo build && rustc --version && cargo --version",
	
	// Environment variables
	"remoteEnv": {
		"PATH": "/home/vscode/.local/bin:/usr/local/cargo/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin",
		"RUST_BACKTRACE": "1",
		"NEO4J_URI": "bolt://neo4j:7687",
		"NEO4J_USER": "neo4j",
		"NEO4J_PASSWORD": "password",
         "HTTPS_PROXY": "${localEnv:https_proxy}",
         "HTTP_PROXY": "${localEnv:http_proxy}",
         "https_proxy": "${localEnv:https_proxy}",
         "http_proxy": "${localEnv:http_proxy}",
		"no_proxy": "10.203.14.28,localhost,.example.internal,172.26.16.1,127.0.0.1,::1,neo4j",
		"NO_PROXY": "10.203.14.28,localhost,.example.internal,172.26.16.1,127.0.0.1,::1,neo4j"
	},
	
	// Mount the cargo cache to avoid re-downloading dependencies
	"mounts": [
		"source=cargo-cache,target=/usr/local/cargo,type=volume",
		// Mount SSH directory from host for GitLab access
		"source=${localEnv:HOME}${localEnv:USERPROFILE}/.ssh,target=/home/vscode/.ssh,type=bind,consistency=cached"
	]
}
