<?xml version="1.0" encoding="UTF-8"?>
<portlet-app xmlns="http://java.sun.com/xml/ns/portlet"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="http://java.sun.com/xml/ns/portlet 
             http://java.sun.com/xml/ns/portlet/portlet-app_2_0.xsd"
             version="2.0">

    <portlet>
        <portlet-name>UserPortlet</portlet-name>
        <portlet-class>com.example.UserPortlet</portlet-class>
        
        <supports>
            <mime-type>text/html</mime-type>
        </supports>
        
        <portlet-info>
            <title>User Management</title>
            <short-title>Users</short-title>
            <keywords>user,management</keywords>
        </portlet-info>
        
        <init-param>
            <name>template</name>
            <value>user-template.jsp</value>
        </init-param>
    </portlet>
    
    <portlet>
        <portlet-name>AdminPortlet</portlet-name>
        <portlet-class>com.example.AdminPortlet</portlet-class>
        
        <supports>
            <mime-type>text/html</mime-type>
        </supports>
        
        <portlet-info>
            <title>Administration</title>
            <short-title>Admin</short-title>
        </portlet-info>
    </portlet>

</portlet-app>
